# Neon — usar URL con pooler (-pooler) en desarrollo para evitar "Connection terminated"
# Ej: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Opcional: máximo de conexiones del pool local (default 5)
# DATABASE_POOL_MAX=5

# Clerk — copiar exactas desde dashboard.clerk.com
# Dashboard → User & Authentication → Email, Password: habilitar "Password" en Sign-in y Sign-up
# Usar comillas SIMPLES si la publishable key termina en $ (dotenv lo trunca sin comillas)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY='pk_test_...'
CLERK_SECRET_KEY='sk_test_...'
# Desactiva modo keyless en desarrollo cuando ya tienes keys del dashboard
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=1
# Proxy Frontend API — solo producción (detrás de reverse proxy). No usar en npm run dev.
# NEXT_PUBLIC_CLERK_PROXY_URL=/__clerk

# Webhook — Dashboard Clerk → Webhooks → endpoint /api/webhooks/clerk
CLERK_WEBHOOK_SECRET='whsec_...'

# URL pública de producción (sin barra final). En local, npm run dev define NEXT_PUBLIC_DEV_ORIGIN automáticamente.
NEXT_PUBLIC_APP_URL=https://www.pragmapms.com
APP_URL=https://www.pragmapms.com
# NEXT_PUBLIC_DEV_ORIGIN=http://localhost:3000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/panel
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Sync en servidor: GET /api/cron/airbnb-ical-sync
# Renovación suscripción: GET /api/cron/billing-renewal
# CRON_SECRET=

# PriceLabs Customer API (Open API)
# Opción A: pegar la API key en Integraciones → PriceLabs (recomendado, se guarda cifrada)
# Opción B: variable de entorno (fallback si no hay key en BD)
# PRICELABS_API_KEY=
# PRICELABS_BASE_URL=https://api.pricelabs.co
# PRICELABS_PMS_NAME=other
# PRICELABS_API_ENABLED=false
#   ↑ solo si quieres modo simulación sin llamadas reales (por defecto: live)
# PRICELABS_TIMEOUT_MS=300000
# Cron: GET /api/cron/pricelabs-sync (Bearer CRON_SECRET)
# Tras desplegar: npm run db:migrate:deploy

# Wompi (Colombia — tokenized billing, no raw card storage in PRAGMA)
# WOMPI_PUBLIC_KEY=pub_test_...
# WOMPI_PRIVATE_KEY=prv_test_...
# WOMPI_EVENTS_SECRET=
# WOMPI_INTEGRITY_SECRET=
# WOMPI_ENV=test
#   test | sandbox → sandbox; production | prod → live
# WOMPI_BASE_URL=https://sandbox.wompi.co/v1
# WOMPI_WEBHOOK_URL=https://pragma-pms.vercel.app/api/payments/wompi/webhook

# PRAGMA_BANK_ACCOUNT=
# PRAGMA_BANK_HOLDER=PRAGMA SAS
# PRAGMA_BANK_NIT=
# PRAGMA_BILLING_EMAIL=facturacion@pragma.co

# Correos transaccionales (factura al pagar suscripción)
# RESEND_API_KEY=re_...
# EMAIL_FROM="PRAGMA Facturación <facturacion@pragma.co>"

# TTLock Smart Access — credenciales de la app PRAGMA (solo servidor)
# TTLOCK_CLIENT_ID=
# TTLOCK_CLIENT_SECRET=
# TTLOCK_ENCRYPTION_KEY=
# TTLOCK_API_ENABLED=true
# Authorize UI (browser login): euopen | Token + API: euapi
# TTLOCK_OAUTH_WEB_URL=https://euopen.ttlock.com
# TTLOCK_API_BASE_URL=https://euapi.ttlock.com
# Callback canónica — única fuente para OAuth TTLock (registrar EXACTA en TTLock Open Platform):
TTLOCK_REDIRECT_URI=https://www.pragmapms.com/api/integrations/ttlock/callback
# OAuth navegador (true en producción por defecto; false = solo conexión por cuenta)
# TTLOCK_BROWSER_OAUTH=true

# Platform Super Admin Owner (global tenant visibility)
# PLATFORM_OWNER_EMAIL=bsionaryup@gmail.com
# NEXT_PUBLIC_PLATFORM_OWNER_EMAIL=bsionaryup@gmail.com
# Owner login: /owner-login (email OTP via Clerk)
# PLATFORM_IMPERSONATION_SECRET=  # optional; falls back to CLERK_SECRET_KEY
# PLATFORM_IMPERSONATION_TTL_MS=7200000

# SIRE (Migración Colombia) — prueba de conexión real desde Integraciones → SIRE
# Por defecto: portal JSF (documento + contraseña del portal SIRE).
# Client ID = número de documento | Client Secret = código tipo doc (ej. 10) | API Key = contraseña
# Callback URL = ID de empresa (formLogin:listaEmpresa) si aplica
# SIRE_PORTAL_BASE_URL=https://apps.migracioncolombia.gov.co
# SIRE_PORTAL_LOGIN_PATH=/sire/public/login.jsf
# SIRE_REQUEST_TIMEOUT_MS=30000
# SIRE_DEFAULT_DOCUMENT_TYPE=10
# Modo API partner (opcional): define SIRE_API_BASE_URL y credenciales OAuth en el formulario
# SIRE_AUTH_MODE=portal
# SIRE_API_BASE_URL=
# SIRE_API_TOKEN_PATH=/oauth/token
# SIRE_API_TEST_PATH=/health
# SIRE_API_GRANT_TYPE=client_credentials
# SIRE_API_SCOPE=

# TRAA / TRA PMS (MINCIT) — Integraciones → TRAA
# Client ID = RNT | Token = token PMS (pms.mincit.gov.co/token) | API Key = alternativa al Token
# TRAA_API_BASE_URL=https://pms.mincit.gov.co
# TRAA_API_PRIMARY_PATH=/one/
# TRAA_REQUEST_TIMEOUT_MS=30000
# Por defecto la prueba solo valida el token (POST {}); no registra huésped de prueba.
# TRAA_TEST_SEND_PAYLOAD=true
# TRAA_TEST_PAYLOAD_JSON={"tipo_identificacion":"C.C",...}
