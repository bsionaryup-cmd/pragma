# Neon — usar URL con pooler (-pooler) en desarrollo para evitar "Connection terminated"
# Ej: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Opcional: máximo de conexiones del pool local (default 5)
# DATABASE_POOL_MAX=5

# Clerk — copiar exactas desde dashboard.clerk.com
# Dashboard → User & Authentication → Email, Password: habilitar "Password" en Sign-in y Sign-up
# Usar comillas SIMPLES si la publishable key termina en $ (dotenv lo trunca sin comillas)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY='pk_test_...'
CLERK_SECRET_KEY='sk_test_...'
# Desactiva modo keyless en desarrollo cuando ya tienes keys del dashboard
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=1
# Proxy Frontend API — solo producción (detrás de reverse proxy). No usar en npm run dev.
# NEXT_PUBLIC_CLERK_PROXY_URL=/__clerk

# Webhook — Dashboard Clerk → Webhooks → endpoint /api/webhooks/clerk
CLERK_WEBHOOK_SECRET='whsec_...'

# URL pública de producción (sin barra final)
NEXT_PUBLIC_APP_URL=https://pragma-pms.vercel.app
APP_URL=https://pragma-pms.vercel.app
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/panel
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/panel

# Sync en servidor: GET /api/cron/airbnb-ical-sync
# CRON_SECRET=

# PriceLabs Customer API (Open API)
# PRICELABS_API_KEY=
# PRICELABS_BASE_URL=https://api.pricelabs.co
# PRICELABS_PMS_NAME=other
# PRICELABS_API_ENABLED=true
# PRICELABS_TIMEOUT_MS=300000
# Cron: GET /api/cron/pricelabs-sync (Bearer CRON_SECRET)
# Tras desplegar: npm run db:migrate:deploy

# TTLock Smart Access
# TTLOCK_ENCRYPTION_KEY=
# TTLOCK_API_ENABLED=true
# TTLOCK_API_BASE_URL=https://euapi.ttlock.com
# TTLOCK_OAUTH_WEB_URL=https://euopen.ttlock.com
# Callback canónica (registrar EXACTA en TTLock Open Platform):
TTLOCK_REDIRECT_URI=https://pragma-pms.vercel.app/api/integrations/ttlock/callback
# OAuth navegador (true en producción por defecto; false = solo conexión por cuenta)
# TTLOCK_BROWSER_OAUTH=true
