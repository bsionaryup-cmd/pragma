{
  "name": "pragma-pms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:clear": "npm run dev:clean",
    "dev:doctor": "node scripts/dev-doctor.mjs",
    "build": "npm run brand:favicon && prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "verify:env": "node scripts/verify-env.mjs",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:sync": "node scripts/sync-prisma.mjs",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:repair:ttlock": "node scripts/repair-ttlock-schema.mjs",
    "db:repair:user": "node scripts/repair-user-schema.mjs",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:purge-demo": "node scripts/purge-demo-artifacts.mjs",
    "db:purge-test": "node scripts/purge-test-data.mjs",
    "db:purge-accounts": "node scripts/purge-tenant-accounts.mjs",
    "db:seed:demo": "node scripts/seed-demo-data.mjs",
    "db:provision:demo-user": "node scripts/provision-demo-test-user.mjs",
    "user:admin": "node scripts/set-admin-role.mjs",
    "validate:ical": "node scripts/validate-ical-export.mjs && node scripts/validate-ical-sync.mjs",
    "validate:ttlock-callback": "node scripts/validate-ttlock-callback.mjs",
    "audit:ical": "node scripts/run-ical-sync-audit.mjs",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "brand:favicon": "node scripts/brand/generate-favicon.mjs",
    "test:billing": "npx tsx --test tests/billing/*.test.ts tests/rbac/*.test.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.5",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "svix": "^1.93.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
