// PRAGMA PMS — Schema base MVP
// PostgreSQL (Neon / Supabase) + Prisma 7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ───────────────────────────────────────────────────
// Sincronizado con Clerk (webhook en módulo Auth)

model User {
  id          String    @id @default(cuid())
  clerkId     String    @unique
  email       String    @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  role        UserRole  @default(OPERATIONS)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  properties    Property[]
  assignedTasks Task[] @relation("TaskAssignee")
  ttlockIntegrations TTLockIntegration[]

  @@index([role, isActive])
  @@map("users")
}

enum UserRole {
  ADMIN
  OPERATIONS
}

// ─── Property ─────────────────────────────────────────────────

model Property {
  id                 String         @id @default(cuid())
  ownerId            String
  name               String
  description        String?
  address            String
  neighborhood       String?
  city               String
  country            String         @default("CO")
  propertyType       PropertyType   @default(APARTMENT)
  maxGuests          Int
  bedrooms           Int
  beds               Int            @default(1)
  bathrooms          Decimal        @db.Decimal(3, 1)
  checkInTime        String?        @default("15:00")
  checkOutTime       String?        @default("11:00")
  accessCode         String?
  accessInstructions String?
  wifiName           String?
  wifiPassword       String?
  houseRules         String?
  baseRate           Decimal?       @db.Decimal(12, 2)
  cleaningFee        Decimal?       @db.Decimal(12, 2)
  coverImageUrl      String?
  airbnbListingUrl   String?
  airbnbRoomId       String?
  icalUrl            String?
  icalExportToken    String?        @unique
  lastIcalSyncedAt   DateTime?
  status             PropertyStatus @default(ACTIVE)
  currency           String         @default("COP")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  tasks        Task[]
  propertyLock PropertyLock?

  @@index([ownerId, status])
  @@index([airbnbRoomId])
  @@map("properties")
}

enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  ROOM
  OTHER
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// ─── Reservation ──────────────────────────────────────────────

model Reservation {
  id                           String            @id @default(cuid())
  propertyId                   String
  guestName                    String
  guestFirstName               String            @default("")
  guestLastName                String?
  guestEmail                   String?
  guestPhone                   String?
  guestCountry                 String?
  guestLanguage                String?
  adults                       Int               @default(1)
  children                     Int               @default(0)
  infants                      Int               @default(0)
  checkIn                      DateTime          @db.Date
  checkOut                     DateTime          @db.Date
  platform                     BookingPlatform
  status                       ReservationStatus @default(CONFIRMED)
  totalAmount                  Decimal           @db.Decimal(12, 2)
  currency                     String            @default("COP")
  internalNotes                String?
  icalUid                      String?
  guestRegistrationToken       String?           @unique
  guestRegistrationCompletedAt DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  property                Property                 @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  guests                  ReservationGuest[]
  guestRegistrationTokens GuestRegistrationToken[]
  accessCredentials       AccessCredential[]
  accessEvents            AccessEvent[]
  tasks                   Task[]

  @@unique([propertyId, icalUid])
  @@index([propertyId, checkIn, checkOut])
  @@index([status])
  @@map("reservations")
}

model ReservationGuest {
  id             String   @id @default(cuid())
  reservationId  String
  isPrimary      Boolean  @default(false)
  firstName      String
  lastName       String
  fullName       String
  documentType   String
  documentNumber String
  email          String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([reservationId, documentType, documentNumber])
  @@unique([reservationId, documentNumber])
  @@index([reservationId, isPrimary])
  @@map("reservation_guests")
}

model GuestRegistrationToken {
  id              String                  @id @default(cuid())
  reservationId   String
  token           String                  @unique
  status          GuestRegistrationStatus @default(ACTIVE)
  expiresAt       DateTime?
  usedAt          DateTime?
  revokedAt       DateTime?
  attempts        Int                     @default(0)
  maxAttempts     Int                     @default(10)
  createdBySystem Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId, status])
  @@index([token, status])
  @@map("guest_registration_tokens")
}

enum GuestRegistrationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  REVOKED
}

model TTLockIntegration {
  id                    String                  @id @default(cuid())
  userId                String
  clientId              String?
  clientSecretEncrypted String?
  username              String?
  passwordHash          String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  uid                   String?
  expiresAt             DateTime?
  environment           TTLockEnvironment       @default(PRODUCTION)
  redirectUri           String?
  lastError             String?
  status                TTLockIntegrationStatus @default(PENDING_SETUP)
  lastSyncedAt          DateTime?
  lastTokenRefreshAt    DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyLocks      PropertyLock[]
  automationSettings TTLockAutomationSettings?
  accessEvents       AccessEvent[]

  @@unique([userId])
  @@index([status])
  @@map("ttlock_integrations")
}

model PropertyLock {
  id            String         @id @default(cuid())
  integrationId String
  propertyId    String         @unique
  ttlockLockId  String?
  alias         String?
  timezone      String?
  lockStatus    TTLockLockStatus @default(UNMAPPED)
  onlineState   TTLockOnlineState @default(UNKNOWN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  integration       TTLockIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  accessCredentials AccessCredential[]

  @@index([integrationId])
  @@index([ttlockLockId])
  @@map("property_locks")
}

model TTLockAutomationSettings {
  id                                   String                   @id @default(cuid())
  integrationId                        String                   @unique
  generateAfterGuestRegistration        Boolean                  @default(false)
  revokeAfterCheckout                  Boolean                  @default(true)
  requireManualApproval                Boolean                  @default(true)
  autoSendCode                         Boolean                  @default(false)
  allowRegeneration                    Boolean                  @default(true)
  expirationStrategy                   TTLockExpirationStrategy @default(CHECKOUT_TIME)
  createdAt                            DateTime                 @default(now())
  updatedAt                            DateTime                 @updatedAt

  integration TTLockIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("ttlock_automation_settings")
}

model AccessCredential {
  id             String                       @id @default(cuid())
  reservationId  String
  propertyLockId String?
  ttlockCodeId   String?
  codeEncrypted  String?
  validFrom      DateTime?
  validTo        DateTime?
  status         AccessCredentialStatus       @default(PENDING)
  deliveryStatus AccessCredentialDeliveryStatus @default(NOT_SENT)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  reservation  Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  propertyLock PropertyLock? @relation(fields: [propertyLockId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([propertyLockId])
  @@index([status])
  @@map("access_credentials")
}

model AccessEvent {
  id            String          @id @default(cuid())
  reservationId String?
  integrationId String?
  eventType     AccessEventType
  payload       Json?
  createdAt     DateTime        @default(now())

  reservation Reservation?      @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  integration TTLockIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([integrationId])
  @@index([eventType])
  @@map("access_events")
}

enum TTLockIntegrationStatus {
  NOT_CONNECTED
  CONNECTING
  PENDING_SETUP
  CONNECTED
  INVALID_CREDENTIALS
  TOKEN_EXPIRED
  SYNC_ERROR
  READY
}

enum TTLockEnvironment {
  PRODUCTION
  SANDBOX
}

enum TTLockLockStatus {
  UNMAPPED
  MAPPED
  SYNCED
  SYNC_ERROR
}

enum TTLockOnlineState {
  UNKNOWN
  ONLINE
  OFFLINE
}

enum TTLockExpirationStrategy {
  CHECKOUT_TIME
  CHECKOUT_PLUS_BUFFER
  MANUAL
}

enum AccessCredentialStatus {
  PENDING
  GENERATED
  SENT
  ACTIVE
  EXPIRED
  REVOKED
}

enum AccessCredentialDeliveryStatus {
  NOT_SENT
  PENDING
  SENT
  FAILED
}

enum AccessEventType {
  TOKEN_REFRESHED
  LOCK_SYNCED
  LOCK_SYNC_FAILED
  CODE_GENERATION_READY
  CODE_GENERATED
  CODE_REVOKED
}

enum BookingPlatform {
  AIRBNB
  BOOKING
  DIRECT
}

enum ReservationStatus {
  CONFIRMED
  CHECKED_IN
  CHECKOUT_TODAY
  CHECKED_OUT
  CANCELLED
  BLOCKED
}

// ─── Task ─────────────────────────────────────────────────────

model Task {
  id            String     @id @default(cuid())
  propertyId    String?
  reservationId String?
  assigneeId    String?
  type          TaskType
  title         String
  description   String?
  dueDate       DateTime?
  status        TaskStatus @default(PENDING)
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  property    Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([assigneeId, status])
  @@index([propertyId, status])
  @@map("tasks")
}

enum TaskType {
  CLEANING
  CHECK_IN
  MAINTENANCE
  LAUNDRY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
