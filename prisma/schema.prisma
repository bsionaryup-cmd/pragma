// PRAGMA PMS — Schema base MVP
// PostgreSQL (Neon / Supabase) + Prisma 7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Organization (multi-tenant workspace) ─────────────────

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

model Organization {
  id        String             @id @default(cuid())
  name      String
  status    OrganizationStatus @default(ACTIVE)
  suspendedAt DateTime?
  deletedAt DateTime?
  deletedReason String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  users          User[]
  billingAccount BillingAccount?
  wompiIntegration WompiIntegration?
  ttlockIntegration TTLockIntegration?
  properties     Property[]
  impersonationSessions PlatformImpersonationSession[]
  organizationIntegrations OrganizationIntegration[]
  supportTickets         SupportTicket[]
  guestPaymentLinks      GuestPaymentLink[]
  salesQuotes            SalesQuote[]

  @@map("organizations")
}

// ─── User ───────────────────────────────────────────────────
// Sincronizado con Clerk (webhook en módulo Auth)

model User {
  id          String    @id @default(cuid())
  clerkId     String    @unique
  email       String    @unique
  firstName   String?
  lastName    String?
  imageUrl    String?
  role        UserRole  @default(RECEPTIONIST)
  isAccountOwner Boolean @default(false)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  locale      String    @default("es")
  theme       String    @default("light")
  timezone    String    @default("America/Bogota")
  lastLoginAt DateTime?
  onboardingCompletedAt DateTime?
  companyName       String?
  phone             String?
  propertyCount     Int?
  organizationId    String?
  platformRole      PlatformRole @default(NONE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization         Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  properties           Property[]
  assignedTasks        Task[]                 @relation("TaskAssignee")
  ttlockIntegrations   TTLockIntegration[]
  ttlockConfigured     TTLockIntegration[]  @relation("TTLockConfigurator")
  loginActivities      LoginActivity[]
  manualExpenses       ManualExpense[]        @relation("ManualExpenseCreator")
  otherIncomes         OtherIncome[]          @relation("OtherIncomeCreator")
  externalIntegrations ExternalIntegration[]  @relation("ExternalIntegrationConfigurator")
  priceLabsIntegration PriceLabsIntegration?    @relation("PriceLabsConfigurator")
  organizationIntegrations OrganizationIntegration[] @relation("OrgIntegrationConfigurator")
  wompiIntegrations      WompiIntegration[]       @relation("WompiConfigurator")
  platformImpersonationSessions PlatformImpersonationSession[] @relation("PlatformImpersonator")
  platformAuditLogs      PlatformAuditLog[]
  supportTickets         SupportTicket[] @relation("SupportTicketCreator")
  supportTicketsAssigned SupportTicket[] @relation("SupportTicketAssignee")
  guestPaymentLinks      GuestPaymentLink[] @relation("GuestPaymentLinkCreator")
  salesQuotesCreated     SalesQuote[] @relation("SalesQuoteCreator")
  salesDiscountCodesCreated SalesDiscountCode[] @relation("SalesDiscountCodeCreator")
  salesQuoteEvents       SalesQuoteEvent[] @relation("SalesQuoteEventActor")

  @@index([role, isActive])
  @@index([organizationId])
  @@index([platformRole])
  @@map("users")
}

enum PlatformRole {
  NONE
  SUPER_ADMIN_OWNER
}

enum UserRole {
  ADMIN
  RECEPTIONIST
}

model LoginActivity {
  id          String              @id @default(cuid())
  userId      String
  ipAddress   String?
  userAgent   String?
  deviceLabel String?
  status      LoginActivityStatus @default(SUCCESS)
  createdAt   DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("login_activities")
}

enum LoginActivityStatus {
  SUCCESS
  FAILED
}

// ─── Property ─────────────────────────────────────────────────

model Property {
  id                 String         @id @default(cuid())
  ownerId            String
  organizationId     String?
  name               String
  unitNumber         String?
  description        String?
  address            String
  neighborhood       String?
  city               String
  country            String         @default("CO")
  propertyType       PropertyType   @default(APARTMENT)
  maxGuests          Int
  bedrooms           Int
  beds               Int            @default(1)
  bathrooms          Decimal        @db.Decimal(3, 1)
  checkInTime        String?        @default("15:00")
  checkOutTime       String?        @default("13:00")
  accessCode         String?
  accessInstructions String?
  wifiName           String?
  wifiPassword       String?
  houseRules         String?
  baseRate           Decimal?       @db.Decimal(12, 2)
  cleaningFee        Decimal?       @db.Decimal(12, 2)
  coverImageUrl      String?
  airbnbListingUrl   String?
  airbnbRoomId       String?
  icalUrl            String?
  icalExportToken    String?        @unique
  lastIcalSyncedAt   DateTime?
  status             PropertyStatus @default(ACTIVE)
  currency           String         @default("COP")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  reservations Reservation[]
  tasks        Task[]
  propertyLock PropertyLock?
  priceLabs      PropertyPriceLabs?
  guestPaymentLinks GuestPaymentLink[]

  @@index([ownerId, status])
  @@index([organizationId, status])
  @@index([status])
  @@index([airbnbRoomId])
  @@map("properties")
}

enum PropertyType {
  APARTMENT
  LOFT
  HOUSE
  STUDIO
  ROOM
  OTHER
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// ─── Reservation ──────────────────────────────────────────────

model Reservation {
  id                           String            @id @default(cuid())
  propertyId                   String
  guestName                    String
  guestFirstName               String            @default("")
  guestLastName                String?
  guestEmail                   String?
  guestPhone                   String?
  guestCountry                 String?
  guestLanguage                String?
  adults                       Int               @default(1)
  children                     Int               @default(0)
  infants                      Int               @default(0)
  checkIn                      DateTime          @db.Date
  checkOut                     DateTime          @db.Date
  platform                     BookingPlatform
  status                       ReservationStatus @default(CONFIRMED)
  paymentStatus                PaymentStatus     @default(PAID)
  reservationCode              String?
  totalAmount                  Decimal           @db.Decimal(12, 2)
  currency                     String            @default("COP")
  internalNotes                String?
  icalUid                      String?
  guestRegistrationToken       String?           @unique
  guestRegistrationCompletedAt DateTime?
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  property                Property                 @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  guests                  ReservationGuest[]
  guestRegistrationTokens GuestRegistrationToken[]
  accessCredentials       AccessCredential[]
  accessEvents            AccessEvent[]
  tasks                   Task[]
  paymentInvoices         PaymentInvoice[]
  guestPaymentLinks       GuestPaymentLink[]

  @@unique([propertyId, icalUid])
  @@index([propertyId, checkIn, checkOut])
  @@index([status])
  @@index([status, checkIn])
  @@index([createdAt(sort: Desc)])
  @@map("reservations")
}

model ReservationGuest {
  id                 String                 @id @default(cuid())
  reservationId      String
  isPrimary          Boolean                @default(false)
  isReservationOwner Boolean                @default(false)
  status             ReservationGuestStatus @default(REGISTERED)
  firstName          String
  lastName           String
  fullName           String
  documentType       String
  documentNumber     String
  email              String?
  phone              String?
  nationality        String?
  dateOfBirth        DateTime?              @db.Date
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([reservationId, documentType, documentNumber])
  @@unique([reservationId, documentNumber])
  @@index([reservationId, isPrimary])
  @@index([reservationId, status])
  @@map("reservation_guests")
}

enum ReservationGuestStatus {
  PENDING_REGISTRATION
  REGISTERED
  VERIFIED
  CHECKED_IN
  CHECKED_OUT
}

model GuestRegistrationToken {
  id              String                  @id @default(cuid())
  reservationId   String
  token           String                  @unique
  status          GuestRegistrationStatus @default(ACTIVE)
  expiresAt       DateTime?
  usedAt          DateTime?
  revokedAt       DateTime?
  attempts        Int                     @default(0)
  maxAttempts     Int                     @default(10)
  createdBySystem Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId, status])
  @@index([token, status])
  @@map("guest_registration_tokens")
}

enum GuestRegistrationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  REVOKED
}

model TTLockIntegration {
  id                    String                  @id @default(cuid())
  userId                String
  organizationId        String?                 @unique
  configuredById        String?
  gatewayId             String?
  isActive              Boolean                 @default(true)
  clientId              String?
  clientSecretEncrypted String?
  username              String?
  passwordHash          String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  uid                   String?
  expiresAt             DateTime?
  environment           TTLockEnvironment       @default(PRODUCTION)
  redirectUri           String?
  lastError             String?
  status                TTLockIntegrationStatus @default(PENDING_SETUP)
  lastSyncedAt          DateTime?
  lastTokenRefreshAt    DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization?              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configuredBy       User?                      @relation("TTLockConfigurator", fields: [configuredById], references: [id], onDelete: SetNull)
  propertyLocks      PropertyLock[]
  automationSettings TTLockAutomationSettings?
  accessEvents       AccessEvent[]

  @@unique([userId])
  @@index([status])
  @@index([organizationId])
  @@map("ttlock_integrations")
}

model PropertyLock {
  id            String         @id @default(cuid())
  integrationId String
  propertyId    String         @unique
  ttlockLockId  String?
  alias         String?
  gatewayId     String?
  batteryLevel  Int?
  timezone      String?
  lockStatus    TTLockLockStatus @default(UNMAPPED)
  onlineState   TTLockOnlineState @default(UNKNOWN)
  lastSyncAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  integration       TTLockIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  property          Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  accessCredentials AccessCredential[]

  @@index([integrationId])
  @@index([ttlockLockId])
  @@map("property_locks")
}

model TTLockAutomationSettings {
  id                                   String                   @id @default(cuid())
  integrationId                        String                   @unique
  generateAfterGuestRegistration        Boolean                  @default(false)
  revokeAfterCheckout                  Boolean                  @default(true)
  requireManualApproval                Boolean                  @default(true)
  autoSendCode                         Boolean                  @default(false)
  allowRegeneration                    Boolean                  @default(true)
  expirationStrategy                   TTLockExpirationStrategy @default(CHECKOUT_TIME)
  createdAt                            DateTime                 @default(now())
  updatedAt                            DateTime                 @updatedAt

  integration TTLockIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("ttlock_automation_settings")
}

model AccessCredential {
  id             String                       @id @default(cuid())
  organizationId String?
  reservationId  String
  guestId        String?
  propertyLockId String?
  ttlockCodeId   String?
  codeEncrypted  String?
  validFrom      DateTime?
  validTo        DateTime?
  type           AccessCodeType               @default(GUEST)
  status         AccessCredentialStatus       @default(PENDING)
  deliveryStatus AccessCredentialDeliveryStatus @default(NOT_SENT)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  reservation  Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  propertyLock PropertyLock? @relation(fields: [propertyLockId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([organizationId])
  @@index([propertyLockId])
  @@index([status])
  @@map("access_credentials")
}

model AccessEvent {
  id            String          @id @default(cuid())
  reservationId String?
  integrationId String?
  eventType     AccessEventType
  payload       Json?
  createdAt     DateTime        @default(now())

  reservation Reservation?      @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  integration TTLockIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([integrationId])
  @@index([eventType])
  @@map("access_events")
}

enum TTLockIntegrationStatus {
  NOT_CONNECTED
  CONNECTING
  PENDING_SETUP
  CONNECTED
  INVALID_CREDENTIALS
  TOKEN_EXPIRED
  SYNC_ERROR
  READY
}

enum TTLockEnvironment {
  PRODUCTION
  SANDBOX
}

enum TTLockLockStatus {
  UNMAPPED
  MAPPED
  SYNCED
  SYNC_ERROR
}

enum TTLockOnlineState {
  UNKNOWN
  ONLINE
  OFFLINE
}

enum TTLockExpirationStrategy {
  CHECKOUT_TIME
  CHECKOUT_PLUS_BUFFER
  MANUAL
}

enum AccessCodeType {
  GUEST
  OWNER
  CLEANER
  MAINTENANCE
}

enum AccessCredentialStatus {
  PENDING
  GENERATED
  SENT
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum AccessCredentialDeliveryStatus {
  NOT_SENT
  PENDING
  SENT
  FAILED
}

enum AccessEventType {
  TOKEN_REFRESHED
  LOCK_SYNCED
  LOCK_SYNC_FAILED
  CODE_GENERATION_READY
  CODE_GENERATED
  CODE_REVOKED
}

enum BookingPlatform {
  AIRBNB
  BOOKING
  DIRECT
}

enum ReservationStatus {
  CONFIRMED
  CHECKED_IN
  CHECKOUT_TODAY
  CHECKED_OUT
  CANCELLED
  BLOCKED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

// ─── Finance (manual records) ─────────────────────────────────

enum ManualPaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

model ManualExpense {
  id            String              @id @default(cuid())
  createdById   String
  category      String
  amount        Decimal             @db.Decimal(12, 2)
  currency      String              @default("COP")
  paymentMethod ManualPaymentMethod
  expenseDate   DateTime            @db.Date
  description   String?
  attachmentUrl String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  createdBy User @relation("ManualExpenseCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([expenseDate])
  @@index([createdById])
  @@map("manual_expenses")
}

model OtherIncome {
  id          String   @id @default(cuid())
  createdById String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("COP")
  incomeType  String
  incomeDate  DateTime @db.Date
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation("OtherIncomeCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([incomeDate])
  @@index([createdById])
  @@map("other_incomes")
}

// ─── Organization integrations (multi-tenant) ─────────────────

enum OrganizationIntegrationProvider {
  PRICELABS
}

enum OrganizationIntegrationStatus {
  NOT_CONNECTED
  CONNECTED
  INVALID_KEY
  SYNC_REQUIRED
  SYNC_FAILED
  DEGRADED
}

model OrganizationIntegration {
  id                   String                          @id @default(cuid())
  organizationId       String
  provider             OrganizationIntegrationProvider
  apiKeyEncrypted      String?
  isConnected          Boolean                         @default(false)
  connectedAt          DateTime?
  lastSyncAt           DateTime?
  lastListingsSyncAt   DateTime?
  lastPricesSyncAt     DateTime?
  lastHealthCheckAt    DateTime?
  syncInProgressAt     DateTime?
  status               OrganizationIntegrationStatus   @default(NOT_CONNECTED)
  lastError            String?
  metadata             Json?
  neighborhoodSnapshot Json?
  configuredById       String?
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configuredBy User?        @relation("OrgIntegrationConfigurator", fields: [configuredById], references: [id], onDelete: SetNull)

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider, status])
  @@map("organization_integrations")
}

// ─── PriceLabs dynamic pricing ─────────────────────────────────

enum PriceLabsIntegrationStatus {
  NOT_CONNECTED
  PENDING_SETUP
  CONNECTED
  SYNC_ERROR
  DEGRADED
}

model PriceLabsIntegration {
  id                        String                     @id @default("singleton")
  status                    PriceLabsIntegrationStatus @default(NOT_CONNECTED)
  integrationTokenEncrypted String?
  integrationName           String?
  userTokenEncrypted        String?
  syncInProgressAt          DateTime?
  neighborhoodSnapshot      Json?
  lastHealthCheckAt         DateTime?
  lastListingsSyncAt        DateTime?
  lastPricesSyncAt          DateTime?
  lastError                 String?
  configuredById            String?                    @unique
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  configuredBy User? @relation("PriceLabsConfigurator", fields: [configuredById], references: [id], onDelete: SetNull)

  @@map("pricelabs_integrations")
}

model PriceLabsSyncLog {
  id             String   @id @default(cuid())
  organizationId String?
  action         String
  result         String
  message        String?
  source         String   @default("system")
  meta           Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("pricelabs_sync_logs")
}

enum PropertyPriceLabsSyncStatus {
  PENDING
  SYNCED
  ERROR
}

model PropertyPriceLabs {
  propertyId        String                      @id
  listingId         String?
  recommendedRate   Decimal?                    @db.Decimal(12, 2)
  baseRateAtSync    Decimal?                    @db.Decimal(12, 2)
  priceDelta        Decimal?                    @db.Decimal(12, 2)
  weekendUpliftPct  Decimal?                    @db.Decimal(8, 4)
  syncStatus        PropertyPriceLabsSyncStatus @default(PENDING)
  lastSyncedAt      DateTime?
  lastError         String?
  meta              Json?
  updatedAt         DateTime                    @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("property_pricelabs")
}

// ─── Government integrations (SIRE / TRAA) ────────────────────

enum ExternalIntegrationProvider {
  SIRE
  TRAA
}

enum ExternalIntegrationStatus {
  NOT_CONNECTED
  PENDING_SETUP
  CONNECTED
  ERROR
}

model ExternalIntegration {
  id                    String                      @id @default(cuid())
  provider              ExternalIntegrationProvider @unique
  apiKeyEncrypted       String?
  tokenEncrypted        String?
  clientId              String?
  clientSecretEncrypted String?
  callbackUrl           String?
  status                ExternalIntegrationStatus @default(NOT_CONNECTED)
  lastError             String?
  lastTestedAt          DateTime?
  configuredById        String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  configuredBy User? @relation("ExternalIntegrationConfigurator", fields: [configuredById], references: [id], onDelete: SetNull)

  @@map("external_integrations")
}

// ─── Task ─────────────────────────────────────────────────────

model Task {
  id            String     @id @default(cuid())
  propertyId    String?
  reservationId String?
  assigneeId    String?
  type          TaskType
  title         String
  description   String?
  dueDate       DateTime?
  status        TaskStatus @default(PENDING)
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  property    Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([assigneeId, status])
  @@index([propertyId, status])
  @@map("tasks")
}

enum TaskType {
  CLEANING
  CHECK_IN
  MAINTENANCE
  LAUNDRY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Billing (SaaS subscription — Colombia / Wompi-ready) ───

enum BillingSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  LOCKED
}

enum BillingPlanCode {
  STARTER
  PRO
  SCALE
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  FAILED
  VOID
}

// ─── Wompi (PSP Colombia) ─────────────────────────────────────

model WompiIntegration {
  id                       String   @id @default(cuid())
  organizationId           String   @unique
  publicKey                String?
  privateKeyEncrypted      String?
  eventsSecretEncrypted    String?
  integritySecretEncrypted String?
  env                      String   @default("test")
  enabled                  Boolean  @default(true)
  lastHealthCheckAt        DateTime?
  lastError                String?
  configuredById           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configuredBy User?        @relation("WompiConfigurator", fields: [configuredById], references: [id], onDelete: SetNull)

  @@map("wompi_integrations")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  DISCARDED
}

model Lead {
  id              String     @id @default(cuid())
  fullName        String
  email           String
  phone           String?
  propertyCount   Int?
  message         String?
  source          String     @default("landing")
  status          LeadStatus @default(NEW)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([email])
  @@index([status, createdAt])
  @@map("leads")
}

model BillingAccount {
  id                    String                    @id @default(cuid())
  organizationId        String?                   @unique
  status                BillingSubscriptionStatus @default(TRIAL)
  plan                  BillingPlanCode           @default(STARTER)
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  gracePeriodEndsAt     DateTime?
  billingLockedAt       DateTime?
  wompiCustomerRef      String?
  defaultPaymentTokenRef String?
  metadata              Json?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     BillingInvoice[]

  @@map("billing_accounts")
}

model BillingInvoice {
  id                 String               @id @default(cuid())
  billingAccountId   String               @default("singleton")
  amount             Decimal              @db.Decimal(12, 2)
  currency           String               @default("COP")
  status             BillingInvoiceStatus @default(OPEN)
  description        String?
  dueAt              DateTime
  paidAt             DateTime?
  externalRef        String?              @unique
  wompiTransactionId String?
  failureReason      String?
  manualPaymentRef   String?
  manualPaymentNote  String?
  manualSubmittedAt  DateTime?
  invoiceEmailSentAt DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  account         BillingAccount   @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  paymentInvoices PaymentInvoice[]

  @@index([billingAccountId, status])
  @@index([dueAt])
  @@map("billing_invoices")
}

// ─── Payments ledger (PSP-agnostic — Wompi-ready) ───────────────────────────

enum PaymentProviderCode {
  WOMPI
  STRIPE
  MERCADOPAGO
  PAYU
  MANUAL
}

enum PaymentTransactionStatus {
  PENDING
  APPROVED
  DECLINED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentInvoiceLedgerStatus {
  DRAFT
  OPEN
  PAID
  FAILED
  VOID
  CANCELLED
}

enum PaymentMethodType {
  CARD
  PSE
  NEQUI
  TRANSFER
  OTHER
}

enum PaymentRefundStatus {
  PENDING
  APPROVED
  FAILED
}

model PaymentInvoice {
  id               String                     @id @default(cuid())
  tenantId         String                     @default("singleton")
  billingInvoiceId String?
  reservationId    String?
  guestId          String?
  subtotal         Decimal                    @db.Decimal(12, 2)
  fees             Decimal                    @default(0) @db.Decimal(12, 2)
  taxes            Decimal                    @default(0) @db.Decimal(12, 2)
  total            Decimal                    @db.Decimal(12, 2)
  currency         String                     @default("COP")
  status           PaymentInvoiceLedgerStatus @default(OPEN)
  dueAt            DateTime
  paidAt           DateTime?
  description      String?
  metadata         Json?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  billingInvoice BillingInvoice?    @relation(fields: [billingInvoiceId], references: [id], onDelete: SetNull)
  reservation    Reservation?       @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  transactions   PaymentTransaction[]
  attempts       PaymentAttempt[]
  refunds        PaymentRefund[]

  @@index([tenantId, status])
  @@index([billingInvoiceId])
  @@index([reservationId])
  @@index([dueAt])
  @@map("payment_invoices")
}

model PaymentTransaction {
  id                String                   @id @default(cuid())
  tenantId          String                   @default("singleton")
  reservationId     String?
  invoiceId         String?
  guestId           String?
  amount            Decimal                  @db.Decimal(12, 2)
  currency          String                   @default("COP")
  paymentMethod     PaymentMethodType        @default(OTHER)
  provider          PaymentProviderCode      @default(WOMPI)
  providerReference String?
  status            PaymentTransactionStatus @default(PENDING)
  fees              Decimal                  @default(0) @db.Decimal(12, 2)
  taxes             Decimal                  @default(0) @db.Decimal(12, 2)
  idempotencyKey    String?                  @unique
  metadata          Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  invoice  PaymentInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  attempts PaymentAttempt[]
  refunds  PaymentRefund[]

  @@index([tenantId, status])
  @@index([provider, providerReference])
  @@index([invoiceId])
  @@index([reservationId])
  @@index([createdAt])
  @@map("payment_transactions")
}

model PaymentAttempt {
  id            String                   @id @default(cuid())
  tenantId      String                   @default("singleton")
  invoiceId     String
  transactionId String?
  attemptNumber Int                      @default(1)
  provider      PaymentProviderCode      @default(WOMPI)
  status        PaymentTransactionStatus @default(PENDING)
  amount        Decimal                  @db.Decimal(12, 2)
  currency      String                   @default("COP")
  failureReason String?
  metadata      Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  invoice     PaymentInvoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  transaction PaymentTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([invoiceId, attemptNumber])
  @@index([tenantId, status])
  @@map("payment_attempts")
}

model PaymentRefund {
  id                String              @id @default(cuid())
  tenantId          String              @default("singleton")
  invoiceId         String
  transactionId     String
  amount            Decimal             @db.Decimal(12, 2)
  currency          String              @default("COP")
  status            PaymentRefundStatus @default(PENDING)
  provider          PaymentProviderCode @default(WOMPI)
  providerReference String?
  reason            String?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  invoice     PaymentInvoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  transaction PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([transactionId])
  @@index([tenantId, status])
  @@map("payment_refunds")
}

model PaymentWebhookLog {
  id             String              @id @default(cuid())
  tenantId       String              @default("singleton")
  provider       PaymentProviderCode @default(WOMPI)
  eventType      String
  eventId        String
  signatureValid Boolean             @default(false)
  processed      Boolean             @default(false)
  duplicate      Boolean             @default(false)
  payload        Json
  errorMessage   String?
  createdAt      DateTime            @default(now())

  @@unique([provider, eventId])
  @@index([tenantId, createdAt])
  @@index([processed])
  @@map("payment_webhook_logs")
}

model PaymentAuditLog {
  id         String   @id @default(cuid())
  tenantId   String   @default("singleton")
  entityType String
  entityId   String
  action     String
  actorId    String?
  before     Json?
  after      Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([createdAt])
  @@map("payment_audit_logs")
}

// ─── Platform owner (Super Admin) ───────────────────────────

enum PlatformImpersonationStatus {
  ACTIVE
  ENDED
  EXPIRED
}

model PlatformImpersonationSession {
  id                   String                      @id @default(cuid())
  platformUserId       String
  targetOrganizationId String
  status               PlatformImpersonationStatus @default(ACTIVE)
  startedAt            DateTime                    @default(now())
  endedAt              DateTime?
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  deviceLabel          String?
  endReason            String?

  platformUser       User         @relation("PlatformImpersonator", fields: [platformUserId], references: [id], onDelete: Cascade)
  targetOrganization Organization @relation(fields: [targetOrganizationId], references: [id], onDelete: Cascade)

  @@index([platformUserId, status])
  @@index([targetOrganizationId, status])
  @@index([expiresAt])
  @@map("platform_impersonation_sessions")
}

model PlatformAuditLog {
  id               String   @id @default(cuid())
  ownerEmail       String
  platformUserId   String
  action           String
  targetTenantId   String?
  targetUserId     String?
  ipAddress        String?
  userAgent        String?
  deviceLabel      String?
  previousState    Json?
  newState         Json?
  metadata         Json?
  createdAt        DateTime @default(now())

  platformUser User @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId, createdAt(sort: Desc)])
  @@index([targetTenantId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("platform_audit_logs")
}

// ─── Support Center ─────────────────────────────────────────

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED
  ESCALATED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketCategory {
  BUG
  BILLING
  RESERVATIONS
  INTEGRATIONS
  ACCESS
  OTHER
}

model SupportTicket {
  id              String                @id @default(cuid())
  organizationId  String?
  createdById     String
  assignedToId    String?
  subject         String
  category        SupportTicketCategory   @default(OTHER)
  priority        SupportTicketPriority   @default(NORMAL)
  status          SupportTicketStatus     @default(OPEN)
  routeContext    String?
  propertyId      String?
  reservationId   String?
  autoContext     Json?
  screenshotUrl   String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  resolvedAt      DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy    User          @relation("SupportTicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignedTo   User?         @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     SupportMessage[]

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([assignedToId, status, updatedAt(sort: Desc)])
  @@index([createdById, createdAt(sort: Desc)])
  @@map("support_tickets")
}

model SupportMessage {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?
  authorKind String   @default("tenant")
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

// ─── Tenant guest payment links (Wompi per tenant — not SaaS billing) ───

enum GuestPaymentLinkStatus {
  DRAFT
  SENT
  PENDING
  PROCESSING
  PAID
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum GuestPaymentCategory {
  RESERVATION_FULL
  DEPOSIT
  REMAINING_BALANCE
  DAMAGE_FEE
  CLEANING_FEE
  LATE_CHECKOUT
  EXTRA_SERVICES
  MANUAL_OPERATIONAL
}

model GuestPaymentLink {
  id               String                 @id @default(cuid())
  organizationId   String
  createdById      String
  reservationId    String?
  propertyId       String?
  guestName        String?
  category         GuestPaymentCategory
  description      String
  amount           Decimal                @db.Decimal(12, 2)
  currency         String                 @default("COP")
  status           GuestPaymentLinkStatus @default(DRAFT)
  wompiLinkId      String?
  wompiCheckoutUrl String?
  expiresAt        DateTime?
  notes            String?
  paymentInvoiceId String?
  metadata         Json?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User          @relation("GuestPaymentLinkCreator", fields: [createdById], references: [id], onDelete: Cascade)
  reservation    Reservation?  @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  property       Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([reservationId])
  @@map("guest_payment_links")
}

// ─── Sales Console (SaaS offers — platform owner only) ───

enum SalesQuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  EXPIRED
  CANCELLED
  CONVERTED
}

enum SalesBillingInterval {
  MONTHLY
  ANNUAL
}

enum SalesDiscountScope {
  GLOBAL
  PLAN
  TENANT
}

enum SalesDiscountKind {
  PERCENT
  FIXED_COP
}

model SalesDiscountCode {
  id              String             @id @default(cuid())
  createdById     String
  code            String             @unique
  label           String?
  kind            SalesDiscountKind
  value           Decimal            @db.Decimal(12, 2)
  scope           SalesDiscountScope @default(GLOBAL)
  plan            BillingPlanCode?
  organizationId  String?
  firstMonthOnly  Boolean            @default(false)
  recurring       Boolean            @default(true)
  maxRedemptions  Int?
  redemptionCount Int                @default(0)
  expiresAt       DateTime?
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  createdBy User         @relation("SalesDiscountCodeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  quotes    SalesQuote[]

  @@index([active, expiresAt])
  @@map("sales_discount_codes")
}

model SalesQuote {
  id                String               @id @default(cuid())
  createdById       String
  organizationId    String?
  prospectName      String?
  prospectEmail     String?
  plan              BillingPlanCode
  propertyCount     Int
  billingInterval   SalesBillingInterval @default(MONTHLY)
  discountPercent   Decimal?             @db.Decimal(5, 2)
  discountAmountCop Decimal?             @db.Decimal(12, 2)
  discountCodeId    String?
  listAmountCop     Decimal              @db.Decimal(12, 2)
  savingsAmountCop  Decimal              @default(0) @db.Decimal(12, 2)
  finalAmountCop    Decimal              @db.Decimal(12, 2)
  currency          String               @default("COP")
  status            SalesQuoteStatus     @default(DRAFT)
  offerToken        String?              @unique
  expiresAt         DateTime?
  acceptedAt        DateTime?
  convertedAt       DateTime?
  notes             String?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  createdBy    User               @relation("SalesQuoteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  organization Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  discountCode SalesDiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  events       SalesQuoteEvent[]

  @@index([status, createdAt(sort: Desc)])
  @@index([prospectEmail])
  @@index([organizationId])
  @@map("sales_quotes")
}

model SalesQuoteEvent {
  id        String   @id @default(cuid())
  quoteId   String
  action    String
  actorId   String?
  payload   Json?
  createdAt DateTime @default(now())

  quote SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  actor User?      @relation("SalesQuoteEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([quoteId, createdAt])
  @@map("sales_quote_events")
}
